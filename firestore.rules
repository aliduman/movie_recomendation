rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Film sohbet odası
    match /movies/{movieId}/chat/{messageId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.uid;
    }

    // Film yorumları
    match /movies/{movieId}/comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.uid;
    }

    // User-scoped app data
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /favorites/{movieId} {
        allow read, write: if isOwner(userId);
      }

      match /recommendations/{movieId} {
        allow read, write: if isOwner(userId);
      }

      match /chatParticipation/{movieId} {
        allow read, write: if isOwner(userId);
      }

      match /settings/{doc} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}

