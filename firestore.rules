rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRequiredString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function isOptionalString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function isDirectMessageParticipant(dmId) {
      return isSignedIn() && (
        (
          dmId.matches('^' + request.auth.uid + '_[^_]+$') &&
          !dmId.matches('^' + request.auth.uid + '_' + request.auth.uid + '$')
        ) ||
        (
          dmId.matches('^[^_]+_' + request.auth.uid + '$') &&
          !dmId.matches('^' + request.auth.uid + '_' + request.auth.uid + '$')
        )
      );
    }

    function isValidChatCreate(data) {
      return data.keys().hasOnly(['uid', 'displayName', 'photoURL', 'text', 'createdAt']) &&
        data.uid == request.auth.uid &&
        isOptionalString(data.displayName, 120) &&
        isOptionalString(data.photoURL, 2048) &&
        isRequiredString(data.text, 2000) &&
        data.createdAt == request.time;
    }

    function isValidChatUpdate() {
      return request.resource.data.keys().hasOnly(['uid', 'displayName', 'photoURL', 'text', 'createdAt', 'editedAt']) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.displayName == resource.data.displayName &&
        request.resource.data.photoURL == resource.data.photoURL &&
        request.resource.data.createdAt == resource.data.createdAt &&
        isRequiredString(request.resource.data.text, 2000) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['text', 'editedAt']);
    }

    function isValidCommentCreate(data) {
      return data.keys().hasOnly(['uid', 'displayName', 'photoURL', 'text', 'createdAt']) &&
        data.uid == request.auth.uid &&
        isOptionalString(data.displayName, 120) &&
        isOptionalString(data.photoURL, 2048) &&
        isRequiredString(data.text, 2000) &&
        data.createdAt == request.time;
    }

    function isValidCommentUpdate() {
      return request.resource.data.keys().hasOnly(['uid', 'displayName', 'photoURL', 'text', 'createdAt', 'editedAt']) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.displayName == resource.data.displayName &&
        request.resource.data.photoURL == resource.data.photoURL &&
        request.resource.data.createdAt == resource.data.createdAt &&
        isRequiredString(request.resource.data.text, 2000) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['text', 'editedAt']);
    }

    function isValidDmMetadata() {
      return request.resource.data.keys().hasOnly(['lastMessage', 'lastAt', 'otherUid']) &&
        isRequiredString(request.resource.data.lastMessage, 2000) &&
        isRequiredString(request.resource.data.otherUid, 128) &&
        request.resource.data.lastAt == request.time;
    }

    function isValidOwnDmMetadata(userId, dmId) {
      return isOwner(userId) &&
        request.resource.data.otherUid != request.auth.uid &&
        (
          dmId == request.auth.uid + '_' + request.resource.data.otherUid ||
          dmId == request.resource.data.otherUid + '_' + request.auth.uid
        );
    }

    function isValidPeerDmMetadata(userId, dmId) {
      return isSignedIn() &&
        userId != request.auth.uid &&
        request.resource.data.otherUid == request.auth.uid &&
        (
          dmId == request.auth.uid + '_' + userId ||
          dmId == userId + '_' + request.auth.uid
        );
    }

    function isValidDmMessageCreate(data) {
      return data.keys().hasOnly(['uid', 'displayName', 'photoURL', 'text', 'createdAt']) &&
        data.uid == request.auth.uid &&
        isOptionalString(data.displayName, 120) &&
        isOptionalString(data.photoURL, 2048) &&
        isRequiredString(data.text, 2000) &&
        data.createdAt == request.time;
    }

    // Film sohbet odası
    match /movies/{movieId}/chat/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidChatCreate(request.resource.data);
      allow update: if isSignedIn() && request.auth.uid == resource.data.uid && isValidChatUpdate();
      allow delete: if isSignedIn() && request.auth.uid == resource.data.uid;
    }

    // Film yorumları
    match /movies/{movieId}/comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidCommentCreate(request.resource.data);
      allow update: if isSignedIn() && request.auth.uid == resource.data.uid && isValidCommentUpdate();
      allow delete: if isSignedIn() && request.auth.uid == resource.data.uid;
    }

    // Bu filmi beğenenler (herkese açık okuma)
    match /movies/{movieId}/likedBy/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    // Kullanıcı profili ve alt koleksiyonlar
    match /users/{userId} {
      // Profil herkese okunabilir, sadece sahip yazabilir
      allow read: if true;
      allow write: if isOwner(userId);

      match /favorites/{movieId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      match /watchlist/{movieId} {
        allow read, write: if isOwner(userId);
      }

      match /watchlists/{watchlistId} {
        allow read, write: if isOwner(userId);

        // Watchlist oluşturma/ekleme akışında owner'ın tüm alt dokümanlara yazabilmesi gerekir.
        // Bu alan sadece users/{uid} altında ve sadece owner'a açık olduğu için kapsam güvenlidir.
        match /{document=**} {
          allow read, write: if isOwner(userId);
        }
      }

      match /recommendations/{movieId} {
        allow read, write: if isOwner(userId);
      }

      match /chatParticipation/{movieId} {
        allow read, write: if isOwner(userId);
      }

      match /settings/{doc} {
        allow read, write: if isOwner(userId);
      }

      // Takipçiler — herkese açık okuma, sahip ve takip eden yazabilir
      match /followers/{followerUid} {
        allow read: if true;
        allow write: if isOwner(followerUid);
      }

      // Takip edilenler — herkese açık okuma, sahip yazabilir
      match /following/{targetUid} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // Direkt mesajlar listesi
      match /dms/{dmId} {
        allow read: if isOwner(userId);
        allow create, update: if isDirectMessageParticipant(dmId) &&
          isValidDmMetadata() &&
          (
            isValidOwnDmMetadata(userId, dmId) ||
            isValidPeerDmMetadata(userId, dmId)
          );
        allow delete: if isOwner(userId);
      }

      // FCM push token'ları
      match /fcmTokens/{token} {
        allow read, write: if isOwner(userId);
      }
    }

    // Direkt mesaj konuşmaları
    match /dms/{dmId}/messages/{messageId} {
      allow read: if isDirectMessageParticipant(dmId);
      allow create: if isDirectMessageParticipant(dmId) && isValidDmMessageCreate(request.resource.data);
    }
  }
}
