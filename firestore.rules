rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Film sohbet odası
    match /movies/{movieId}/chat/{messageId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.uid;
    }

    // Film yorumları
    match /movies/{movieId}/comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.uid;
    }

    // Bu filmi beğenenler (herkese açık okuma)
    match /movies/{movieId}/likedBy/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    // Kullanıcı profili ve alt koleksiyonlar
    match /users/{userId} {
      // Profil herkese okunabilir, sadece sahip yazabilir
      allow read: if true;
      allow write: if isOwner(userId);

      match /favorites/{movieId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      match /recommendations/{movieId} {
        allow read, write: if isOwner(userId);
      }

      match /chatParticipation/{movieId} {
        allow read, write: if isOwner(userId);
      }

      match /settings/{doc} {
        allow read, write: if isOwner(userId);
      }

      // Takipçiler — herkese açık okuma, sahip ve takip eden yazabilir
      match /followers/{followerUid} {
        allow read: if true;
        allow write: if isOwner(followerUid);
      }

      // Takip edilenler — herkese açık okuma, sahip yazabilir
      match /following/{targetUid} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // Direkt mesajlar listesi
      match /dms/{dmId} {
        allow read, write: if isOwner(userId);
      }

      // FCM push token'ları
      match /fcmTokens/{token} {
        allow read, write: if isOwner(userId);
      }
    }

    // Direkt mesaj konuşmaları
    match /dms/{dmId}/messages/{messageId} {
      allow read: if isSignedIn() && (
        dmId.matches(request.auth.uid + '_.*') ||
        dmId.matches('.*_' + request.auth.uid)
      );
      allow create: if isSignedIn() && (
        dmId.matches(request.auth.uid + '_.*') ||
        dmId.matches('.*_' + request.auth.uid)
      );
    }
  }
}
